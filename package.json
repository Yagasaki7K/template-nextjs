{
    "name": "blank-project",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "vercel": "next build",
        "start": "next start",
        "lint": "eslint",
        "next:update": "bun add next@latest react@latest react-dom@latest eslint-config-next@latest",
        "commit": "git pull && bun update && bun getSecurity.ts && bun run vercel && read -p 'Descriptions\n Commit: ' message && git add . && echo -n \"$message - \" && node getTime.js | xargs -I {} git commit -m \"$message - {}\" && git push",
        "clean": "rm -rf node_modules && bun install"
    },
    "dependencies": {
        "next": "^16.2.9",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "sonner": "^2.0.7",
        "styled-components": "^6.4.2",
        "supabase": "^2.106.0"
    },
    "devDependencies": {
        "@types/node": "^20.19.43",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "eslint": "^9.39.4",
        "eslint-config-next": "^16.2.9",
        "typescript": "^5.9.3"
    },
    "ignoreScripts": [
        "sharp",
        "unrs-resolver"
    ],
    "trustedDependencies": [
        "sharp",
        "unrs-resolver"
    ]
}